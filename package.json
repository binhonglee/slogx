{
  "name": "slogx-ui",
  "version": "0.0.3",
  "type": "module",
  "description": "Real-time backend log viewer",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.js",
    "docs:dev": "docusaurus start website --port 3001",
    "docs:build": "docusaurus build website --out-dir build",
    "docs:smg": "docusaurus-smg ./website --output ./website/smg-temp --name 'slogx docs' --base-uri docs && cp -r ./website/smg-temp/* ./website/build/ && rm -rf ./website/smg-temp",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "SLOGX_PYTHON=\"./.venv/bin/python\" playwright test",
    "test:e2e:ui": "SLOGX_PYTHON=\"./.venv/bin/python\" playwright test --ui",
    "test:integration": "vitest run tests/integration",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "lucide-preact": "1.20.0",
    "preact": "10.29.2",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@playwright/test": "1.61.0",
    "@preact/preset-vite": "2.10.5",
    "@testing-library/preact": "3.2.4",
    "@types/node": "25.9.3",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.9",
    "docusaurus-smg": "0.0.4",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
