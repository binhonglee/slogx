{
  "name": "slogx-ui",
  "version": "0.0.2",
  "type": "module",
  "description": "Real-time backend log viewer",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.js",
    "docs:dev": "docusaurus start website --port 3001",
    "docs:build": "docusaurus build website --out-dir build",
    "docs:smg": "docusaurus-smg ./website --output ./website/smg-temp --name 'slogx docs' --base-uri docs && cp -r ./website/smg-temp/* ./website/build/ && rm -rf ./website/smg-temp",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "SLOGX_PYTHON=\"./.venv/bin/python\" playwright test",
    "test:e2e:ui": "SLOGX_PYTHON=\"./.venv/bin/python\" playwright test --ui"
  },
  "dependencies": {
    "lucide-preact": "0.469.0",
    "preact": "10.25.4",
    "ws": "8.18.1"
  },
  "devDependencies": {
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@playwright/test": "1.59.1",
    "@preact/preset-vite": "2.10.2",
    "@testing-library/preact": "3.2.4",
    "@types/node": "25.0.3",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.4",
    "docusaurus-smg": "0.0.4",
    "jsdom": "27.3.0",
    "typescript": "5.9.3",
    "vite": "7.3.0",
    "vitest": "4.1.4"
  }
}
